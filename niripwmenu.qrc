<RCC>
    <qresource prefix="/src/qml">
        <file alias="Main.qml">src/qml/Main.qml</file>
        <file alias="Style.qml">src/qml/Style.qml</file>
    </qresource>
    <qresource prefix="/">
        <file>data/config.json</file>
        <file>data/shutdown.png</file>
        <file>data/reboot.png</file>
        <file>data/logoff.png</file>
    </qresource>
</RCC>